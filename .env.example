# Copy this file to .env and fill in your values
# Only needed for running examples with real LLMs — tests use MockLLM

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Database ---
# SQLite is the zero-config default. Set these to use the local Postgres.
# Dev DB for the examples:
DENDRUX_DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/dendrux

# Postgres test DB for the integration matrix (`pytest tests/integration`).
# The harness auto-rewrites the database name to end in `_test` (→ dendrux_test)
# and creates it on first use. Unset → Postgres is skipped (SQLite-only).
DENDRUX_TEST_PG_URL=postgresql+asyncpg://postgres:root@localhost:5432/dendrux
